PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=replace_with_secure_random_string
JWT_REFRESH_SECRET=replace_with_secure_random_string

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional cache
REDIS_URL=rediss://default:<token>@<host>:6379

# Comma-separated allowed frontend origins for CORS
# Local: http://localhost:5173
# Render static: https://<your-frontend>.onrender.com
CLIENT_URL=http://localhost:5173
